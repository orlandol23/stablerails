{
  "name": "@stablerails/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared kernel: branded money types (USDC 6dp / BRL centavos), FX conversion, correlation ids (UUIDv7 ↔ bytes32)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
