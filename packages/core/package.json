    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@stablerails/config": "workspace:*",
    "@types/node": "22.20.1",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
