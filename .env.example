# ─────────────────────────────────────────────────────────────────────────
# StableRails — environment reference (operator documentation)
#
# Copy to `.env` and adjust. Every variable is validated at startup by
# apps/api/src/env.ts (zod, fail-fast): a bad value stops the process with
# a readable error instead of failing later at 2am. Keep this file and the
# schema in sync — the schema is the source of truth.
#
# TESTNET ONLY. Nothing in this project ever touches mainnet funds.
# ─────────────────────────────────────────────────────────────────────────

# ── API process ──────────────────────────────────────────────────────────
# NODE_ENV: development | test | production
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
# LOG_LEVEL: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ── Backing services (defaults match docker-compose.yml) ────────────────
DATABASE_URL=postgres://stablerails:stablerails@localhost:5432/stablerails
REDIS_URL=redis://localhost:6379

# ── Arrives with the vertical slice (documented early, NOT yet consumed —
#    the env schema will grow as each integration lands) ─────────────────
# Base Sepolia RPC (settlement chain; escrow lives here)
#BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Relayer/operator key — TESTNET ONLY, never a funded mainnet key.
# Generate a fresh one: `cast wallet new` (do NOT reuse other wallets).
#OPERATOR_PRIVATE_KEY=0x...
# OpenPix sandbox AppID (create at https://app.openpix-sandbox.com → API/Plugins)
#OPENPIX_APP_ID=...
# HMAC secret of the registered OpenPix webhook (platform → webhook detail)
#OPENPIX_WEBHOOK_SECRET=...
# OTLP endpoint (docker-compose otel-lgtm service)
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
